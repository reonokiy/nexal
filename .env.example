# ── LLM ──────────────────────────────────────────────────
LLM_MODEL=openai/gpt-4o
LLM_API_KEY=sk-xxx
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MAX_CONTEXT_TOKENS=128000
# LLM_TEMPERATURE=0.6
# LLM_SUPPORTS_IMAGES=true

# ── Telegram ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_ALLOW_FROM=user_id_1,username_2
# TELEGRAM_ALLOW_CHATS=chat_id_1,chat_id_2

# ── Discord ──────────────────────────────────────────────
# DISCORD_BOT_TOKEN=xxx
# DISCORD_ALLOW_FROM=user_id_1,username_2
# DISCORD_ALLOW_CHANNELS=channel_id_1,channel_id_2

# ── Bot persona ─────────────────────────────────────────
# BOT_NAME=nexal

# ── Sandbox ──────────────────────────────────────────────
# SANDBOX_IMAGE=ghcr.io/reonokiy/nexal-sandbox:python3.13-debian13
# SANDBOX_RUNTIME=              # e.g. krun for microVM isolation (requires libkrun)
# SANDBOX_NETWORK_ENABLED=false
# SANDBOX_WORKSPACE_READ_ONLY=false

# ── Message timing ───────────────────────────────────────
# MESSAGE_DEBOUNCE_SECONDS=1
# MESSAGE_DELAY_SECONDS=10
# ACTIVE_TIME_WINDOW_SECONDS=60
